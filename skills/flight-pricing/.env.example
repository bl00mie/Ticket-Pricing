# Duffel API access token (required)
# Sign up and get yours at https://app.duffel.com/tokens
# Use a test-mode token (duffel_test_...) for development
DUFFEL_ACCESS_TOKEN=your_duffel_token_here

# Travelpayouts API token (optional — enables price context)
# Sign up at https://app.travelpayouts.com/profile/api-token
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here
